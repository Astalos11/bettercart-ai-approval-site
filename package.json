{
  "name": "bettercart-ai-approval-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:zip": "python3 scripts/create_export_zip.py && npm run check:zip",
    "start": "next start",
    "lint": "echo \"No ESLint config is installed; run npm run check:local for project QA.\"",
    "check:static": "node scripts/check_static_site.js",
    "check:live": "node scripts/check_live_site.js",
    "check:docs": "node scripts/check_docs_index.js",
    "check:zip": "python3 scripts/check_export_zip.py",
    "check:local": "npm run build && npm run check:static && npm run check:docs",
    "check:all": "npm run check:local && npm run check:live"
  },
  "dependencies": {
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {}
}
